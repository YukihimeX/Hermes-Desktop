<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24,32,40" Spacing="20">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock x:Uid="SettingsEyebrow" Style="{StaticResource PageEyebrowTextStyle}" />
                    <TextBlock x:Uid="SettingsTitle" Style="{StaticResource PageTitleTextStyle}" MaxWidth="920" />
                    <TextBlock x:Uid="SettingsSubtitle" Style="{StaticResource BodySecondaryTextStyle}" MaxWidth="920" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="THEME BRAND" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox x:Name="BrandCombo" HorizontalAlignment="Stretch"
                                      Background="{ThemeResource AppInsetBrush}"
                                      BorderBrush="{ThemeResource AppStrokeBrush}"
                                      SelectionChanged="BrandCombo_SelectionChanged">
                                <ComboBoxItem Content="Gemini" Tag="gemini" IsSelected="True"/>
                                <ComboBoxItem Content="Ollama" Tag="ollama"/>
                                <ComboBoxItem Content="Claude" Tag="claude"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="COLOR MODE" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox x:Name="ThemeModeCombo" HorizontalAlignment="Stretch"
                                      Background="{ThemeResource AppInsetBrush}"
                                      BorderBrush="{ThemeResource AppStrokeBrush}"
                                      SelectionChanged="ThemeModeCombo_SelectionChanged">
                                <ComboBoxItem Content="Dark" Tag="Dark" IsSelected="True"/>
                                <ComboBoxItem Content="Light" Tag="Light"/>
                                <ComboBoxItem Content="System Default" Tag="Default"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="SettingsRuntimeTitle" Style="{StaticResource SectionTitleTextStyle}" />
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="PROVIDER" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="ProviderCombo" HorizontalAlignment="Stretch"
                                          Background="{ThemeResource AppInsetBrush}"
                                          BorderBrush="{ThemeResource AppStrokeBrush}"
                                          SelectionChanged="ProviderCombo_SelectionChanged">
                                    <ComboBoxItem Content="Nous (OpenRouter)" Tag="nous"/>
                                    <ComboBoxItem Content="OpenAI" Tag="openai"/>
                                    <ComboBoxItem Content="Anthropic" Tag="anthropic"/>
                                    <ComboBoxItem Content="Qwen (Alibaba)" Tag="qwen"/>
                                    <ComboBoxItem Content="DeepSeek" Tag="deepseek"/>
                                    <ComboBoxItem Content="MiniMax" Tag="minimax"/>
                                    <ComboBoxItem Content="OpenRouter" Tag="openrouter"/>
                                    <ComboBoxItem Content="Custom / Local" Tag="local"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="BASE URL" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="BaseUrlBox" PlaceholderText="http://127.0.0.1:11434/v1"
                                         Background="{ThemeResource AppInsetBrush}"
                                         BorderBrush="{ThemeResource AppStrokeBrush}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="MODEL" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="ModelCombo" HorizontalAlignment="Stretch"
                                          Background="{ThemeResource AppInsetBrush}"
                                          BorderBrush="{ThemeResource AppStrokeBrush}"
                                          SelectionChanged="ModelCombo_SelectionChanged"/>
                                <TextBox x:Name="ModelBox" PlaceholderText="Or type a custom model ID"
                                         Background="{ThemeResource AppInsetBrush}"
                                         BorderBrush="{ThemeResource AppStrokeBrush}" />
                                <TextBlock x:Name="ContextLengthLabel" FontSize="12"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                           Text="Context: --"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="API KEY" Style="{StaticResource LabelTextStyle}"/>
                                <PasswordBox x:Name="ApiKeyBox" PlaceholderText="sk-... (leave blank for local)"
                                             Background="{ThemeResource AppInsetBrush}"
                                             BorderBrush="{ThemeResource AppStrokeBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="SaveModelBtn" Content="Save Model Config" Click="SaveModelConfig_Click"
                                        Background="{ThemeResource AppAccentGradientBrush}"
                                        BorderBrush="{ThemeResource AppAccentDarkBrush}"
                                        Foreground="#16110D" Padding="20,8"/>
                                <TextBlock x:Name="ModelSaveStatus" VerticalAlignment="Center"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
