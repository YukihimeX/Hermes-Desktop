<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HermesDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HermesDesktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#0B0B0B" />
                    <SolidColorBrush x:Key="AppPaneBackgroundBrush" Color="#131314" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#1E1F20" />
                    <SolidColorBrush x:Key="AppInsetBrush" Color="#1A1A1C" />
                    <SolidColorBrush x:Key="AppStrokeBrush" Color="#444746" />
                    <SolidColorBrush x:Key="AppAccentBrush" Color="#1A73E8" />
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#C4C7C5" />
                    <LinearGradientBrush x:Key="AppAccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4285F4" Offset="0.0" />
                        <GradientStop Color="#9B72CB" Offset="0.5" />
                        <GradientStop Color="#D96570" Offset="1.0" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F8F9FA" />
                    <SolidColorBrush x:Key="AppPaneBackgroundBrush" Color="#F0F2F5" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppInsetBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="AppStrokeBrush" Color="#D1D1D1" />
                    <SolidColorBrush x:Key="AppAccentBrush" Color="#1A73E8" />
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#444746" />
                    <LinearGradientBrush x:Key="AppAccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A73E8" Offset="0.0" />
                        <GradientStop Color="#4285F4" Offset="1.0" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Google Sans" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource AppAccentBrush}" />
            </Style>

            <Style x:Key="SurfaceCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="18" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
